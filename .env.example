# Copy this file to agent/.env for LOCAL DEVELOPMENT ONLY.
# Never commit the real agent/.env — it's already in .gitignore.
# On Render, set these as dashboard environment variables instead (see README).

GOOGLE_API_KEY=your-google-ai-studio-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# OpenWeatherMap key, used server-side only (server.py proxies weather calls
# so this never reaches the browser).
OWM_API_KEY=your-openweathermap-key-here

# For local dev you can instead drop a gitignored firebase-key.json next to
# server.py and leave FIREBASE_CREDENTIALS_JSON unset. On Render, paste the
# full contents of your service-account JSON as a single-line value here.
FIREBASE_CREDENTIALS_JSON=
